<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LMS - Requests History</title>
    <link rel="icon" href="/images/CAG Monochrome.png" type="image/png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/reqHistoryStyles.css">
<body>
    <%- include('partials/backButton', { href: '/admin/requests', label: 'BACK' }) %>
    <div class="allData">
        <h1>Reservation History</h1>
        <div class="searchBar">
            <form method="GET" action="/admin/requests/history">
                <input type="text" name="search" placeholder="Search..." value="<%= search || '' %>">
                <button type="submit">Search</button>
                <% if (search) { %>
                    <a href="/admin/requests/history" id="clear">Clear</a>
                <% } %>
            </form>
        </div>
        <div class="tableData">
            <% if (result && result.length > 0) { %>
                <table class="allRecords" border="1">
                    <!-- <caption>Reservation History</caption> -->
                    <tr>
                        <th>Reservation ID</th>
                        <th>Book ID</th>
                        <th>User Name</th>
                        <th>Contact</th>
                        <th>Date and Time of reservation</th>
                        <th>Return Status</th>
                        <th>Returned At</th>
                    </tr>
                    <% result.forEach(r => { %>
                        <tr>
                            <td><%= r.id %></td>
                            <td><%= r.book_id %></td>
                            <td><%= r.name %></td>
                            <td><%= r.contact %></td>
                            <td><%= r.reserved_at.toLocaleString() %></td>
                            <td><%= r.return_status %></td>
                            <td>
                                <% if (r.returned_at) { %>
                                    <%= new Date(r.returned_at).toLocaleString() %>
                                <% } else { %>
                                    Not returned yet
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                </table>
                <% } else { %>
                    <p>No reservations found.</p>
                <% } %>
        </div>
    </div>
</body>
</html>