<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login</title>
    <link rel="icon" href="/images/CAG Monochrome.png" type="image/png">
    <link rel="stylesheet" href="/adminStyles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <% if (success && success.length) { %>
        <div class="flash success"><%= success %></div>
    <% } %>
    <% if (error && error.length) { %>
        <div class="flash error"><%= error %></div>
    <% } %>
        <%- include('partials/backButton', { href: '/', label: 'HOME' }) %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhj6hW+ALEwIH" crossorigin="anonymous">

    <div class="login-container">
        <form id="loginForm" action="/admin" method="post" class="login-box needs-validation" novalidate>
            <img src="/images/Color_Horizontal.png" alt="Library logo" class="admin-logo">
            <h2>LMS Admin Login</h2>
            <label for="username"><i class="fa-solid fa-user"></i>&nbsp;Username:</label>
            <input type="text" name="username" id="username" placeholder="Enter username" required autocomplete="off" minlength="3" maxlength="30" pattern="[A-Za-z0-9._-]+">
            <div class="invalid-feedback"><i class="fa-solid fa-circle-info"></i> Please enter a valid username (3-30 chars, letters/numbers/._-).</div>
            
            <label for="password"><i class="fa-solid fa-key"></i>&nbsp;Password:</label>
            <div class="password-field">
                <input type="password" name="password" id="password" placeholder="Enter password" required autocomplete="off" minlength="4">
                <button type="button" class="password-toggle" id="passwordToggle" aria-label="Show password" aria-pressed="false">
                    <i class="fa-solid fa-eye"></i>
                </button>
            </div>
            <div class="invalid-feedback"><i class="fa-solid fa-circle-info"></i> Password must be at least 4 characters.</div>

            <button type="submit" class="btn-login-blue">LOGIN</button>
        </form>
    </div>
        <script>
        (function () {
            'use strict'
            const form = document.getElementById('loginForm');
            const inputs = Array.from(form.querySelectorAll('input'));
            const feedbacks = Array.from(form.querySelectorAll('.invalid-feedback'));
            const passwordInput = document.getElementById('password');
            const passwordToggle = document.getElementById('passwordToggle');

            // hide feedbacks by default
            feedbacks.forEach(f => { f.style.display = 'none'; f.style.color = '#dc3545'; f.style.marginTop = '0.25rem'; f.style.fontSize = '0.95rem'; });

            // on submit, show feedback only for invalid fields
            form.addEventListener('submit', function (event) {
                // reset visibility
                feedbacks.forEach(f => f.style.display = 'none');

                if (!form.checkValidity()) {
                    event.preventDefault();
                    event.stopPropagation();

                    inputs.forEach(input => {
                        const fb = input.nextElementSibling;
                        if (fb && fb.classList.contains('invalid-feedback')) {
                            if (!input.checkValidity()) {
                                fb.style.display = 'block';
                            }
                        }
                    });
                }
                form.classList.add('was-validated');
            }, false);

            // hide feedback as soon as field becomes valid
            inputs.forEach(input => {
                input.addEventListener('input', function () {
                    const fb = input.nextElementSibling;
                    if (fb && fb.classList.contains('invalid-feedback')) {
                        if (input.checkValidity()) {
                            fb.style.display = 'none';
                        }
                    }
                });
            });

            if (passwordToggle && passwordInput) {
                passwordToggle.addEventListener('click', () => {
                    const isHidden = passwordInput.type === 'password';
                    passwordInput.type = isHidden ? 'text' : 'password';
                    passwordToggle.setAttribute('aria-pressed', String(isHidden));
                    passwordToggle.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
                    passwordToggle.innerHTML = isHidden
                        ? '<i class="fa-solid fa-eye-slash"></i>'
                        : '<i class="fa-solid fa-eye"></i>';
                });
            }

        })();
        </script>
</body>
</html>
